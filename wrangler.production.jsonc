{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "app-vlaina-com",
  "compatibility_date": "2026-03-26",
  "workers_dev": false,
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    {
      "pattern": "app.vlaina.com",
      "custom_domain": true
    }
  ]
}
