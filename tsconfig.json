{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Path Aliases */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@milkdown/*": ["./src/types/milkdown/index.d.ts"],
      "@codemirror/language": ["./vendor/milkdown/packages/crepe/node_modules/@codemirror/language"],
      "@codemirror/language-data": ["./vendor/milkdown/packages/crepe/node_modules/@codemirror/language-data"],
      "@codemirror/state": ["./vendor/milkdown/packages/crepe/node_modules/@codemirror/state"],
      "@codemirror/theme-one-dark": ["./vendor/milkdown/packages/crepe/node_modules/@codemirror/theme-one-dark"],
      "@codemirror/view": ["./vendor/milkdown/packages/crepe/node_modules/@codemirror/view"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
