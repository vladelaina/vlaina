{
  "name": "vlaina",
  "private": true,
  "version": "0.1.6",
  "description": "This could be a magic book~",
  "homepage": "https://vlaina.com",
  "author": "vladelaina",
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "main": "electron/main.mjs",
  "scripts": {
    "preinstall": "node scripts/ensure-not-wsl.mjs install",
    "prepare:desktop-assets": "node scripts/generate-windows-icon.mjs",
    "dev": "node scripts/dev-dynamic.js",
    "dev:renderer": "node scripts/ensure-not-wsl.mjs dev:renderer && vite",
    "dev:renderer:force": "node scripts/ensure-not-wsl.mjs dev:renderer:force && vite --force",
    "dev:electron": "node scripts/ensure-not-wsl.mjs dev:electron && wait-on tcp:3000 && electron .",
    "start": "node scripts/ensure-not-wsl.mjs start && electron .",
    "build": "node scripts/ensure-not-wsl.mjs build && tsc && vite build",
    "build:renderer": "node scripts/ensure-not-wsl.mjs build:renderer && tsc && vite build",
    "build:web": "node scripts/ensure-not-wsl.mjs build:web && tsc && vite build",
    "package:desktop": "node scripts/ensure-not-wsl.mjs package:desktop && pnpm run prepare:desktop-assets && pnpm build && pnpm exec electron-builder --config electron-builder.yml --publish never",
    "package:win": "node scripts/ensure-not-wsl.mjs package:win && pnpm run prepare:desktop-assets && pnpm build && pnpm exec electron-builder --config electron-builder.yml --win --publish never",
    "package:mac": "node scripts/ensure-not-wsl.mjs package:mac && pnpm run prepare:desktop-assets && pnpm build && pnpm exec electron-builder --config electron-builder.yml --mac --publish never",
    "package:linux": "node scripts/ensure-not-wsl.mjs package:linux && pnpm run prepare:desktop-assets && pnpm build && pnpm exec electron-builder --config electron-builder.yml --linux --publish never",
    "deploy:web:staging": "npx wrangler deploy",
    "deploy:web:production": "npx wrangler deploy --config wrangler.production.jsonc",
    "deploy:web:preview:staging": "npx wrangler versions upload",
    "deploy:web:preview:production": "npx wrangler versions upload --config wrangler.production.jsonc",
    "test:language-detection": "node scripts/ensure-not-wsl.mjs test:language-detection && pnpm exec vitest run src/components/Notes/features/Editor/utils/languageDetection/*.test.ts",
    "typecheck": "node scripts/ensure-not-wsl.mjs typecheck && tsc --noEmit --pretty false",
    "test": "node scripts/ensure-not-wsl.mjs test && vitest run",
    "preview": "node scripts/ensure-not-wsl.mjs preview && vite preview",
    "dev:dynamic": "node scripts/dev-dynamic.js",
    "quality:electron-only": "node scripts/assert-electron-only.mjs",
    "quality:language-detection": "node scripts/language-detection-gate.mjs",
    "websearch:ublacklist:candidates": "node scripts/web-search-import-ublacklist.mjs",
    "websearch:rules:install": "node scripts/web-search-install-source-rules.mjs",
    "quality:verify": "pnpm run quality:electron-only && pnpm run typecheck && pnpm run test && pnpm build",
    "quality:budget": "node scripts/check-build-budget.mjs temp/build-quality-gate.log",
    "quality:gate": "node scripts/quality-gate.mjs"
  },
  "dependencies": {
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@heroicons/react": "^2.2.0",
    "@mermaid-js/mermaid-zenuml": "^0.2.2",
    "@milkdown/kit": "workspace:*",
    "@milkdown/plugin-block": "workspace:*",
    "@milkdown/plugin-slash": "workspace:*",
    "@milkdown/react": "workspace:*",
    "@milkdown/theme-nord": "workspace:*",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/postcss": "^4.2.4",
    "@tanstack/react-virtual": "^3.13.24",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/katex": "^0.16.7",
    "@types/node": "^24.10.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.5.0",
    "baseline-browser-mapping": "^2.10.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "concurrently": "^9.2.1",
    "date-fns": "^4.1.0",
    "docx": "^9.6.1",
    "dompurify": "^3.4.2",
    "electron": "41.5.0",
    "electron-builder": "^26.8.1",
    "fast-check": "^4.7.0",
    "framer-motion": "^12.38.0",
    "highlight.js": "^11.11.1",
    "html-to-image": "^1.11.13",
    "jsdom": "^27.3.0",
    "katex": "^0.16.45",
    "lucide-react": "^0.563.0",
    "mermaid": "^11.14.0",
    "micromark-extension-llm-math": "3.1.1-20250610",
    "nanoid": "^5.1.11",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.14",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-dropzone": "^14.3.8",
    "react-easy-crop": "^5.5.7",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "react-tooltip": "^5.30.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shiki": "3.20.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.8.3",
    "unist-util-visit": "^5.1.0",
    "vite": "^7.0.4",
    "vitest": "^4.1.5",
    "wait-on": "^8.0.3",
    "zustand": "^5.0.13"
  },
  "pnpm": {
    "overrides": {
      "lodash-es": "4.18.1"
    },
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
